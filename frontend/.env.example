# Frontend configuration.
#
# Local dev: leave VITE_API_BASE_URL unset — requests use the Vite proxy (/api -> :8080).
# Production (split hosting): set it to your backend's public origin (no trailing slash).
#   On Vercel/Netlify, set this in the project's Environment Variables (not committed here).

# VITE_API_BASE_URL=https://salon-api.onrender.com
