# Copy this file to `.env` (same folder) and fill in your values:
#     cp .env.example .env
# The backend loads `.env` automatically on startup (via spring-dotenv).
# `.env` is git-ignored, so your secrets stay local. Anything left unset falls
# back to the defaults in application.yml.

# --- Admin account (used at /admin/login) ---
ADMIN_EMAIL=admin@salon.local
ADMIN_PASSWORD=admin123

# --- App JWT signing secret (MUST be at least 32 characters) ---
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars
# JWT_TTL_MINUTES=720

# --- Google Sign-In: paste your OAuth Web client id to enable it. Leave blank for guest-only. ---
GOOGLE_CLIENT_ID=28460235950-13nuv3pkp4ru7car02e5vtnoi4kgl9tr.apps.googleusercontent.com

# --- Salon timezone (business hours are interpreted in this zone) ---
SALON_TIMEZONE=Asia/Kolkata

# --- Database (defaults match docker-compose.yml) ---
# DB_URL=jdbc:postgresql://localhost:5432/salon
# DB_USERNAME=salon
# DB_PASSWORD=salon

# --- Notifications: console = log only (default), email = send via SMTP ---
# NOTIFICATIONS_MODE=console
# NOTIFICATIONS_FROM=no-reply@salon.local
# MAIL_HOST=smtp.example.com
# MAIL_PORT=587
# MAIL_USERNAME=you@example.com
# MAIL_PASSWORD=your-app-password
# MAIL_SMTP_AUTH=true
# MAIL_SMTP_STARTTLS=true

# --- CORS: allowed frontend origins (comma-separated) ---
# CORS_ALLOWED_ORIGINS=http://localhost:5173
